<%# ============================================================
    app/views/globe/index.html.erb
    Landing page principale — World Census
    Flow : Globe → Register → Login
    Stack : D3.js v7 + TopoJSON v3 (CDN, zero config)
    Compatible Heroku
    ============================================================ %>

<script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/topojson/3.0.2/topojson.min.js"></script>

  <div style="display:flex;flex-direction:column;width:100%;height:calc(100vh - 60px);background:#020B18;overflow:hidden;">

  <div style="position:absolute;top:8.5rem;left:0;right:0;text-align:center;z-index:10;pointer-events:none;display:flex;align-items:center;justify-content:
  center;gap:8px;">
    <%= image_tag 'favicon.ico', alt: 'World Census logo', style: 'height:1.5rem;width:auto;' %>
    <span style="color:#03C988;font-weight:700;font-size:1.5rem;letter-spacing:.25rem;text-transform:uppercase;font-family:'Raleway',sans-serif;">World
  Census</span>
  </div>
  <%# ── Globe ──────────────────────────────────────────────── %>
  <div id="gc" style="flex:1;display:flex;align-items:center;justify-content:center;position:relative;cursor:grab;user-select:none;overflow:hidden;margin-top:-5.5rem">
    <svg id="gs"></svg>
    <svg id="pins-svg" style="position:absolute;top:0;left:0;pointer-events:none;overflow:visible;"></svg>

    <%# Spinner %>
    <div id="globe-loader" style="position:absolute;display:flex;flex-direction:column;align-items:center;gap:8px;pointer-events:none;">
      <svg width="36" height="36" style="animation:globe-spin 1s linear infinite;">
        <circle cx="18" cy="18" r="14" stroke="#6edff6" stroke-width="3" stroke-dasharray="55 33" fill="none"/>
      </svg>
      <span style="font-size:11px;color:rgba(158,234,249,0.5);letter-spacing:2px;font-family:sans-serif;">LOADING…</span>
    </div>


    <%# ── CTA Auth — visible uniquement aux visiteurs non connectés ── %>
    <% unless user_signed_in? %>
      <div style="
        position:absolute;bottom:1.5rem;left:0;right:0;
        display:flex;flex-direction:column;align-items:center;
        padding:2rem 1.5rem 2.5rem;
        background:linear-gradient(to top, rgba(2,11,24,0.95) 0%, rgba(2,11,24,0.7) 60%, transparent 100%);
        pointer-events:none;
      ">
        <h2 style="
          font-size:1.4rem;font-weight:700;color:#E8EDF5;
          text-align:center;margin:0 0 2.5rem;
          font-family:'Work Sans','Helvetica',sans-serif;
        ">Your global opinion platform</h2>
        <div style="display:flex;flex-direction:column;align-items:center;pointer-events:all;">
          <%= link_to new_user_registration_path,
            style: "background:#03C988;color:#00224D;font-weight:700;border-radius:10px;
                    padding:.75rem 2.5rem;font-size:1rem;text-decoration:none;
                    box-shadow:0 0 20px rgba(3,201,136,0.5);
                    font-family:'Raleway','Helvetica',sans-serif;
                    display:inline-block;" do %>
            Get started &rarr;
          <% end %>
          <%= link_to new_user_session_path,
            style: "color:rgba(232,237,245,0.5);font-size:.85rem;text-decoration:none;
                    font-family:'Raleway','Helvetica',sans-serif;" do %>
            Already have an account? <span style="color: #22c55e; font-weight: bold;">Sign in</span>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if user_signed_in? %>
      <div style="
        position:absolute;bottom:6rem;left:0;right:0;
        display:flex;flex-direction:column;align-items:center;
        padding:1rem 1.5rem 2.5rem;
        background:linear-gradient(to top, rgba(2,11,24,0.95) 0%, rgba(2,11,24,0.7) 60%, transparent 100%);
        pointer-events:none;">

      <h2 style="
          font-size:1.5rem;font-weight:700;color:#E8EDF5;
          text-align:center;margin-bottom:1.5rem;
          font-family:'Work Sans','Helvetica',sans-serif;
        ">Your global opinion platform</h2>

        <div style="display:flex;flex-direction:column;align-items:;gap:.75rem;pointer-events:all;">
          <%= link_to polls_path, class: "btn btn-neon", style: "padding: 0.5rem 2rem !important" do %>
            Continue &rarr;
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<%# Tooltip global %>
<div id="tt" style="
  display:none;position:fixed;background:#031633;border:1px solid #084298;
  border-radius:9px;padding:9px 12px;font-family:'Work Sans','Helvetica',sans-serif;
  pointer-events:none;z-index:9999;max-width:210px;">
</div>

<style>
  @keyframes globe-spin { to { transform: rotate(360deg); } }
</style>
<%# start script %>
<script>
(function(){

  const BLUE = {
    100:'#cfe2ff', 200:'#9ec5fe', 300:'#6ea8fe',
    400:'#3d8bfd', 500:'#0d6efd', 600:'#0a58ca',
    700:'#084298', 800:'#052c65', 900:'#031633',
  };

  const CAT = {
    economy:  { col:'#3d8bfd', label:'Economy'  },
    politics: { col:'#9ec5fe', label:'Politics' },
    social:   { col:'#6ea8fe', label:'Social'   },
    global:   { col:'#cfe2ff', label:'Global'   },
  };

  const COUNTRY_NAMES = {
    "004":"Afghanistan","008":"Albania","012":"Algeria","024":"Angola",
    "032":"Argentina","036":"Australia","040":"Austria","050":"Bangladesh",
    "056":"Belgium","068":"Bolivia","076":"Brazil","100":"Bulgaria",
    "116":"Cambodia","120":"Cameroon","124":"Canada","152":"Chile",
    "156":"China","170":"Colombia","191":"Croatia","192":"Cuba",
    "203":"Czechia","208":"Denmark","218":"Ecuador","818":"Egypt",
    "231":"Ethiopia","246":"Finland","250":"France","276":"Germany",
    "288":"Ghana","300":"Greece","320":"Guatemala","332":"Haiti",
    "348":"Hungary","356":"India","360":"Indonesia","364":"Iran",
    "368":"Iraq","372":"Ireland","376":"Israel","380":"Italy",
    "392":"Japan","400":"Jordan","398":"Kazakhstan","404":"Kenya",
    "408":"North Korea","410":"South Korea","422":"Lebanon","434":"Libya",
    "484":"Mexico","504":"Morocco","508":"Mozambique","524":"Nepal",
    "528":"Netherlands","554":"New Zealand","566":"Nigeria","578":"Norway",
    "586":"Pakistan","604":"Peru","608":"Philippines","616":"Poland",
    "620":"Portugal","634":"Qatar","642":"Romania","643":"Russia",
    "682":"Saudi Arabia","686":"Senegal","706":"Somalia","710":"South Africa",
    "724":"Spain","144":"Sri Lanka","736":"Sudan","752":"Sweden",
    "756":"Switzerland","760":"Syria","764":"Thailand","792":"Turkey",
    "800":"Uganda","804":"Ukraine","784":"UAE","826":"United Kingdom",
    "840":"United States","858":"Uruguay","862":"Venezuela",
    "704":"Vietnam","887":"Yemen","716":"Zimbabwe",
  };

  // Données polls depuis Rails
  const POLLS = <%= @polls.map(&:to_globe_json).to_json.html_safe %>;

  // Grandes villes sans poll
  const CITIES = [
    { lat:34.05, lon:-118.24, city:'Los Angeles',    country:'USA'          },
    { lat:41.88, lon:-87.63,  city:'Chicago',        country:'USA'          },
    { lat:43.65, lon:-79.38,  city:'Toronto',        country:'Canada'       },
    { lat:45.50, lon:-73.57,  city:'Montréal',       country:'Canada'       },
    { lat:49.28, lon:-123.12, city:'Vancouver',      country:'Canada'       },
    { lat:-23.55,lon:-46.63,  city:'São Paulo',      country:'Brazil'       },
    { lat:-22.91,lon:-43.17,  city:'Rio de Janeiro', country:'Brazil'       },
    { lat:-34.60,lon:-58.38,  city:'Buenos Aires',   country:'Argentina'    },
    { lat:4.71,  lon:-74.07,  city:'Bogotá',         country:'Colombia'     },
    { lat:-12.05,lon:-77.04,  city:'Lima',           country:'Peru'         },
    { lat:53.33, lon:-6.25,   city:'Dublin',         country:'Ireland'      },
    { lat:48.21, lon:16.37,   city:'Vienna',         country:'Austria'      },
    { lat:50.85, lon:4.35,    city:'Brussels',       country:'Belgium'      },
    { lat:59.91, lon:10.75,   city:'Oslo',           country:'Norway'       },
    { lat:59.33, lon:18.07,   city:'Stockholm',      country:'Sweden'       },
    { lat:60.17, lon:24.94,   city:'Helsinki',       country:'Finland'      },
    { lat:47.38, lon:8.54,    city:'Zurich',         country:'Switzerland'  },
    { lat:52.37, lon:4.90,    city:'Amsterdam',      country:'Netherlands'  },
    { lat:41.01, lon:28.96,   city:'Istanbul',       country:'Turkey'       },
    { lat:31.77, lon:35.22,   city:'Jerusalem',      country:'Israel'       },
    { lat:25.20, lon:55.27,   city:'Dubai',          country:'UAE'          },
    { lat:24.69, lon:46.72,   city:'Riyadh',         country:'Saudi Arabia' },
    { lat:19.08, lon:72.88,   city:'Mumbai',         country:'India'        },
    { lat:22.54, lon:114.06,  city:'Shenzhen',       country:'China'        },
    { lat:39.93, lon:116.39,  city:'Beijing',        country:'China'        },
    { lat:31.23, lon:121.47,  city:'Shanghai',       country:'China'        },
    { lat:37.57, lon:126.98,  city:'Seoul',          country:'South Korea'  },
    { lat:14.55, lon:121.03,  city:'Manila',         country:'Philippines'  },
    { lat:-6.21, lon:106.85,  city:'Jakarta',        country:'Indonesia'    },
    { lat:13.75, lon:100.52,  city:'Bangkok',        country:'Thailand'     },
    { lat:21.03, lon:105.85,  city:'Hanoi',          country:'Vietnam'      },
    { lat:1.35,  lon:103.82,  city:'Singapore',      country:'Singapore'    },
    { lat:-37.81,lon:144.96,  city:'Melbourne',      country:'Australia'    },
    { lat:6.45,  lon:3.40,    city:'Lagos',          country:'Nigeria'      },
    { lat:-1.29, lon:36.82,   city:'Nairobi',        country:'Kenya'        },
    { lat:33.57, lon:-7.59,   city:'Casablanca',     country:'Morocco'      },
    { lat:-33.93,lon:18.42,   city:'Cape Town',      country:'South Africa' },
    { lat:55.95, lon:-3.19,   city:'Edinburgh',      country:'UK'           },
    { lat:50.06, lon:19.94,   city:'Kraków',         country:'Poland'       },
  ];

  const ALL = [...POLLS, ...CITIES];

  const pollCard     = document.getElementById('poll-card');
  const tt           = document.getElementById('tt');
  const countryLabel = document.getElementById('country-label');

  let hovCountry = null;
  let selCountry = null;
  let hovPin     = null;

  function padId(id) { return String(id).padStart(3, '0'); }

  function capColor(d) {
    const id = padId(d.id);
    if (id === selCountry) return 'rgba(158,234,249,0.90)';
    if (id === hovCountry) return 'rgba(158,234,249,0.55)';
    return 'rgba(158,234,249,0.22)';
  }

  function setPollCard(p) {
    if (!p) {
      pollCard.innerHTML = '<span style="color:#084298;font-size:12px;">Hover a country or city pin</span>';
      return;
    }
    if (p.isPoll) {
      const col = CAT[p.cat]?.col ?? BLUE[400];
      const lab = CAT[p.cat]?.label ?? p.cat;
      pollCard.innerHTML = `
        <div style="width:100%;display:flex;flex-direction:column;gap:5px;">
          <div style="display:flex;gap:6px;align-items:center;">
            <span style="background:#031633;color:${col};font-size:10px;padding:2px 8px;border-radius:4px;font-weight:600;border:1px solid ${col}44;">${lab}</span>
            <span style="color:#6ea8fe;font-size:10px;">${p.city}, ${p.country}</span>
          </div>
          <div style="color:#cfe2ff;font-size:13px;line-height:1.4;">${p.q}</div>
          <div style="color:#084298;font-size:11px;">${p.votes} votes</div>
        </div>`;
    } else {
      pollCard.innerHTML = `<span style="color:#6ea8fe;font-size:12px;"><strong style="color:#9ec5fe;">${p.city}</strong>, ${p.country} — no active poll yet</span>`;
    }
  }

  function init() {
    const gc = document.getElementById('gc');
    const W  = gc.clientWidth  || 800;
    const H  = gc.clientHeight || 600;
    const R  = Math.min(W, H) * 0.45;

    const proj = d3.geoOrthographic()
      .scale(R).translate([W/2, H/2])
      .clipAngle(90).rotate([0, -20]);

    const gpath = d3.geoPath().projection(proj);
    const grat  = d3.geoGraticule()();

    const svg  = d3.select('#gs').attr('width', W).attr('height', H);
    const defs = svg.append('defs');

    defs.append('clipPath').attr('id', 'globe-clip')
      .append('circle').attr('cx', W/2).attr('cy', H/2).attr('r', R);

    const og = defs.append('radialGradient').attr('id', 'ocean-grad').attr('cx','38%').attr('cy','33%');
    og.append('stop').attr('offset','0%').attr('stop-color','#055160');
    og.append('stop').attr('offset','100%').attr('stop-color','#032830');
    svg.append('circle').attr('cx',W/2).attr('cy',H/2).attr('r',R).attr('fill','url(#ocean-grad)');

    const gratPath = svg.append('path').datum(grat)
      .attr('stroke','rgba(13,202,240,0.15)').attr('stroke-width','0.5')
      .attr('fill','none').attr('clip-path','url(#globe-clip)');

    const countryGroup = svg.append('g').attr('clip-path','url(#globe-clip)');

    const borderPath = svg.append('path')
      .attr('fill','none').attr('stroke','rgba(8,121,144,0.85)').attr('stroke-width','0.7')
      .attr('clip-path','url(#globe-clip)');

    const sg = defs.append('radialGradient').attr('id','spec-grad').attr('cx','32%').attr('cy','26%');
    sg.append('stop').attr('offset','0%').attr('stop-color','rgba(158,234,249,0.18)');
    sg.append('stop').attr('offset','55%').attr('stop-color','rgba(158,234,249,0)');
    svg.append('circle').attr('cx',W/2).attr('cy',H/2).attr('r',R)
      .attr('fill','url(#spec-grad)').attr('pointer-events','none');

    const ag = defs.append('radialGradient').attr('id','atmo-grad').attr('cx','50%').attr('cy','50%');
    ag.append('stop').attr('offset','85%').attr('stop-color','rgba(13,202,240,0)');
    ag.append('stop').attr('offset','100%').attr('stop-color','rgba(13,202,240,0.25)');
    svg.append('circle').attr('cx',W/2).attr('cy',H/2).attr('r',R+10)
      .attr('fill','url(#atmo-grad)').attr('pointer-events','none');

    svg.append('circle').attr('cx',W/2).attr('cy',H/2).attr('r',R)
      .attr('fill','none').attr('stroke','rgba(10,162,192,0.65)').attr('stroke-width','1.5')
      .attr('pointer-events','none');

    function isVisible(lat, lon) {
      const r    = proj.rotate();
      const dLon = ((lon - (-r[0]) + 180) % 360 + 360) % 360 - 180;
      const dLat = lat - (-r[1]);
      return Math.abs(dLon) < 88 && Math.abs(dLat) < 88;
    }

    function projectAtR(lat, lon, extra) {
      return d3.geoOrthographic()
        .scale(R + extra).translate([W/2, H/2])
        .clipAngle(90).rotate(proj.rotate())([lon, lat]);
    }

  function drawPins() {
    return;
          psvg.selectAll('*').remove();

      ALL.forEach((p, i) => {
        if (!isVisible(p.lat, p.lon)) return;
        const base = proj([p.lon, p.lat]);
        if (!base) return;

        const isPoll = !!p.isPoll;
        const isH    = hovPin === i;
        const sH     = isH ? 32 : (isPoll ? 20 : 11);
        const tip    = projectAtR(p.lat, p.lon, sH);
        if (!tip) return;

        const col = isPoll
          ? (CAT[p.cat]?.col ?? BLUE[400])
          : (isH ? BLUE[300] : BLUE[700]);

        const g = psvg.append('g')
          .style('cursor', 'pointer')
          .style('pointer-events', 'all');

        g.append('line')
          .attr('x1', base[0]).attr('y1', base[1])
          .attr('x2', tip[0]).attr('y2', tip[1])
          .attr('stroke', isH ? BLUE[100] : (isPoll ? col + 'cc' : BLUE[700]))
          .attr('stroke-width', isH ? 2 : (isPoll ? 1.3 : 0.8));

        g.append('circle')
          .attr('cx', base[0]).attr('cy', base[1])
          .attr('r', isH ? 3 : (isPoll ? 2.2 : 1.5))
          .attr('fill', isH ? BLUE[200] : col);

        g.append('circle')
          .attr('cx', tip[0]).attr('cy', tip[1])
          .attr('r', isH ? (isPoll ? 5.5 : 4) : (isPoll ? 3.5 : 2))
          .attr('fill', isH ? '#ffffff' : col)
          .attr('opacity', isPoll ? 1 : 0.6);

        if (isH) {
          g.append('circle')
            .attr('cx', tip[0]).attr('cy', tip[1])
            .attr('r', 10).attr('fill', 'none')
            .attr('stroke', col + '44').attr('stroke-width', 1.5);
        }

        if (isPoll || isH) {
          const lx = tip[0] + 9, ly = tip[1], fs = isH ? 11 : 9;
          if (isH) {
            const tw = p.city.length * fs * 0.6 + 8;
            g.append('rect')
              .attr('x', lx - 3).attr('y', ly - 8)
              .attr('width', tw).attr('height', 16)
              .attr('rx', 3).attr('fill', 'rgba(3,22,51,0.88)');
          }
          g.append('text')
            .attr('x', lx).attr('y', ly)
            .attr('dominant-baseline', 'middle')
            .attr('font-family', "'Work Sans','Helvetica',sans-serif")
            .attr('font-size', fs).attr('font-weight', isH ? '600' : '500')
            .attr('fill', isH ? BLUE[100] : col)
            .text(p.city);
        }

        g.on('mouseover', function(event) {
            hovPin = i;
            hovCountry = null;
            countryLabel.style.display = 'none';
            setPollCard(p);
            const c2 = isPoll ? (CAT[p.cat]?.col ?? BLUE[400]) : BLUE[300];
            tt.style.display = 'block';
            tt.style.left = (event.clientX + 14) + 'px';
            tt.style.top  = (event.clientY - 10) + 'px';
            tt.innerHTML  = isPoll
              ? `<div style="color:${c2};font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:3px">${p.city} · ${p.country}</div><div style="color:#9ec5fe;font-size:12px;line-height:1.4;margin-bottom:4px">${p.q}</div><div style="color:#084298;font-size:10px;">${p.votes} votes</div>`
              : `<div style="color:${c2};font-size:10px;font-weight:700;margin-bottom:2px">${p.city}</div><div style="color:#6ea8fe;font-size:10px;">${p.country}</div>`;
            redrawCountries();
            drawPins();
          })
          .on('mouseout', function() {
            hovPin = null;
            setPollCard(null);
            tt.style.display = 'none';
            redrawCountries();
            drawPins();
          })
      });
    }

    function redrawCountries() {
      countryGroup.selectAll('path').attr('fill', d => capColor(d));
    }

    let borders = null;
    function redraw() {
      countryGroup.selectAll('path')
        .attr('d', d => gpath(d))
        .attr('fill', d => capColor(d));
      if (borders) borderPath.datum(borders).attr('d', gpath);
      gratPath.attr('d', gpath(grat));
      drawPins();
    }

    d3.json('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json')
      .then(world => {
        document.getElementById('globe-loader').style.display = 'none';
        const countries = topojson.feature(world, world.objects.countries);
        borders = topojson.mesh(world, world.objects.countries, (a, b) => a !== b);

        countryGroup.selectAll('path')
          .data(countries.features).join('path')
          .attr('d', d => gpath(d))
          .attr('fill', d => capColor(d))
          .attr('cursor', 'pointer')
          .on('mouseover', function(event, d) {
            if (hovPin !== null) return;
            hovCountry = padId(d.id);
            countryLabel.textContent = COUNTRY_NAMES[hovCountry] || ('Region ' + hovCountry);
            countryLabel.style.display = 'block';
            redrawCountries();
          })
          .on('mouseout', function(event, d) {
            if (hovPin !== null) return;
            if (padId(d.id) === hovCountry) {
              hovCountry = null;
              countryLabel.style.display = 'none';
              redrawCountries();
            }
          })
          .on('click', function(event, d) {
            selCountry = padId(d.id);
            const name = COUNTRY_NAMES[selCountry] || ('Region ' + selCountry);
            countryLabel.textContent = '📍 ' + name;
            countryLabel.style.display = 'block';
          });

        borderPath.datum(borders).attr('d', gpath);
        gratPath.attr('d', gpath(grat));
        drawPins();
      });

    let rotating = true, lastT = 0;
    (function animate(t) {
      if (rotating && lastT) {
        const dt = t - lastT;
        const r  = proj.rotate();
        proj.rotate([r[0] + dt * 0.006, r[1], r[2]]);
        redraw();
      }
      lastT = t;
      requestAnimationFrame(animate);
    })(0);

    let ds = null, rs = null;
    d3.select('#gc').call(
      d3.drag()
        .on('start', e => { rotating = false; ds = [e.x, e.y]; rs = proj.rotate(); gc.style.cursor = 'grabbing'; })
        .on('drag',  e => { proj.rotate([rs[0] + (e.x - ds[0]) * 0.3, rs[1] - (e.y - ds[1]) * 0.3, rs[2]]); redraw(); })
        .on('end',   () => { rotating = true; gc.style.cursor = 'grab'; })
    );

    window.addEventListener('resize', () => {
      const nW = gc.clientWidth, nH = gc.clientHeight;
      const nR = Math.min(nW, nH) * 0.43;
      svg.attr('width', nW).attr('height', nH);
      d3.select('#pins-svg').attr('width', nW).attr('height', nH);
      proj.translate([nW/2, nH/2]).scale(nR);
      redraw();
    });
  }

  setTimeout(init, 100);
})();
</script>
<%# end script %>
