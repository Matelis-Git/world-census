<div style="background-color: #00224D; min-height: 100vh;">

  <div id="carouselExampleAutoplaying"
    class="carousel slide"
    data-bs-ride="carousel">

    <div class="carousel-inner">

  <div class="carousel-item active">
    <img src="https://res.cloudinary.com/dfz8f4vwe/image/upload/v1779805376/image_1_v8uccs.png"
          width="600"
          height="400"
          class="mx-auto d-block"
          alt="...">
    <div class="carousel-caption">
      <h1 style="color: white;">Explore polls</h1>
      <p style="color: white;">Discover trending community votes</p>
    </div>
  </div>

  <div class="carousel-item">
    <img src="https://res.cloudinary.com/dfz8f4vwe/image/upload/v1779805330/image_2_ekcla9.png"
          width="600"
          height="400"
          class="mx-auto d-block"
          alt="...">
  </div>

  <div class="carousel-item">
    <img src="https://res.cloudinary.com/dfz8f4vwe/image/upload/v1779804998/image_edstto.png"
          width="600"
          height="400"
          class="mx-auto d-block"
          alt="...">
  </div>

  <div class="carousel-item">
    <img src="https://res.cloudinary.com/dfz8f4vwe/image/upload/v1779806241/image_1_rrrnri.png"
          width="600"
          height="400"
          class="mx-auto d-block"
          alt="...">
  </div>

  <div class="carousel-item">
    <img src="https://res.cloudinary.com/dfz8f4vwe/image/upload/v1779806341/image_amipna.png"
          width="600"
          height="400"
          class="mx-auto d-block"
          alt="...">
  </div>

    </div>

    <button class="carousel-control-prev"
            type="button"
            data-bs-target="#carouselExampleAutoplaying"
            data-bs-slide="prev">
      <span class="carousel-control-prev-icon"
            aria-hidden="true"></span>
      <span class="visually-hidden">Previous</span>
    </button>

    <button class="carousel-control-next"
            type="button"
            data-bs-target="#carouselExampleAutoplaying"
            data-bs-slide="next">
      <span class="carousel-control-next-icon"
            aria-hidden="true"></span>
      <span class="visually-hidden">Next</span>
    </button>
  </div>

  <div class="text-center mt-4">
    <button type="button"
            class="btn"
            style="background-color: #03C988;
              border-color: #03C988;
              color: white;">
      Next
    </button>
  </div>

  <div class="text-center mt-4 pb-4">
    <% if user_signed_in? %>
      <%= link_to "homepage", root_path,
          style: "color: white; text-decoration: none;" %>
    <% else %>
      <%= link_to "Skip intro", new_user_session_path,
          style: "color: white; text-decoration: none;" %>
    <% end %>
  </div>

</div>
