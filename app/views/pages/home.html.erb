<div class="demo-page">
  <p class="demo-logo">World Census</p>
  <h1>Explore polls</h1>

  <%# Carousel avec dots et effet neon sur la card active %>
  <div class="neon-card active demo-carousel">
    <div id="demoCarousel" class="carousel slide" data-bs-ride="carousel">
      <div class="carousel-indicators">
        <button type="button" data-bs-target="#demoCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#demoCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#demoCarousel" data-bs-slide-to="2"></button>
        <button type="button" data-bs-target="#demoCarousel" data-bs-slide-to="3"></button>
        <button type="button" data-bs-target="#demoCarousel" data-bs-slide-to="4"></button>
      </div>
      <div class="carousel-inner">
        <div class="carousel-item active">
          <img src="https://res.cloudinary.com/dfz8f4vwe/image/upload/v1779805376/image_1_v8uccs.png" alt="Slide 1">
        </div>
        <div class="carousel-item">
          <img src="https://res.cloudinary.com/dfz8f4vwe/image/upload/v1779805330/image_2_ekcla9.png" alt="Slide 2">
        </div>
        <div class="carousel-item">
          <img src="https://res.cloudinary.com/dfz8f4vwe/image/upload/v1779804998/image_edstto.png" alt="Slide 3">
        </div>
        <div class="carousel-item">
          <img src="https://res.cloudinary.com/dfz8f4vwe/image/upload/v1779806241/image_1_rrrnri.png" alt="Slide 4">
        </div>
        <div class="carousel-item">
          <img src="https://res.cloudinary.com/dfz8f4vwe/image/upload/v1779806341/image_amipna.png" alt="Slide 5">
        </div>
      </div>
    </div>
  </div>

  <%# Bouton principal %>
  <% if user_signed_in? %>
    <%= link_to polls_path, class: "btn btn-neon" do %>
      Explorer &rarr;
    <% end %>
  <% else %>
    <%= link_to new_user_registration_path, class: "btn btn-neon" do %>
      Commencer &rarr;
    <% end %>
  <% end %>

  <%# Lien skip %>
  <% if user_signed_in? %>
    <%= link_to polls_path, class: "link-skip" do %>
      Passer l'intro
    <% end %>
  <% else %>
    <%= link_to new_user_session_path, class: "link-skip" do %>
      J'ai déjà un compte
    <% end %>
  <% end %>
</div>
