<div class="demo-page">
  <p class="demo-logo">World Census</p>
  <h1>Your global opinion platform</h1>

  <div class="neon-card active demo-carousel">
    <div id="demoCarousel" class="carousel slide" data-bs-ride="carousel">
      <div class="carousel-indicators">
        <button type="button" data-bs-target="#demoCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#demoCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#demoCarousel" data-bs-slide-to="2"></button>
        <button type="button" data-bs-target="#demoCarousel" data-bs-slide-to="3"></button>
        <button type="button" data-bs-target="#demoCarousel" data-bs-slide-to="4"></button>
      </div>
      <div class="carousel-inner">
        <div class="carousel-item active">
          <h5 class="carousel-title">Explore polls</h5>
          <img src="https://res.cloudinary.com/dfz8f4vwe/image/upload/v1779805376/image_1_v8uccs.png" alt="Explore polls">
        </div>
        <div class="carousel-item">
          <h5 class="carousel-title">Vote instantly</h5>
          <img src="https://res.cloudinary.com/dfz8f4vwe/image/upload/v1779806341/image_amipna.png" alt="Vote instantly">
        </div>
        <div class="carousel-item">
          <h5 class="carousel-title">Explore by category</h5>
          <img src="https://res.cloudinary.com/dfz8f4vwe/image/upload/v1779804998/image_edstto.png" alt="Explore by category">
        </div>
        <div class="carousel-item">
          <h5 class="carousel-title">Compare your opinion</h5>
          <img src="https://res.cloudinary.com/dfz8f4vwe/image/upload/v1779806241/image_1_rrrnri.png" alt="Compare your opinion">
        </div>
        <div class="carousel-item">
          <h5 class="carousel-title">AI assistant</h5>
          <img src="https://res.cloudinary.com/dfz8f4vwe/image/upload/v1779805330/image_2_ekcla9.png" alt="AI assistant">
        </div>
      </div>
    </div>
  </div>

  <% if user_signed_in? %>
    <%= link_to polls_path, class: "btn btn-neon" do %>
      Continue &rarr;
    <% end %>
  <% else %>
    <%= link_to new_user_registration_path, class: "btn btn-neon" do %>
      Get started &rarr;
    <% end %>
  <% end %>

  <% if user_signed_in? %>
    <%= link_to polls_path, class: "link-skip" do %>
      Go to polls
    <% end %>
  <% else %>
    <%= link_to new_user_session_path, class: "link-skip" do %>
      Already have an account? <span style="color: #22c55e; font-weight: bold;">Sign in</span>
    <% end %>
  <% end %>
</div>
