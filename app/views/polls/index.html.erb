<div class="container my-4">

  <% filter_colors = { "economy" => "#03C988", "politics" => "#FF204E", "social" => "#FFC193", "france" => "#0055A4", "global" => "#4635B1" } %>

  <div class="d-flex gap-2 mb-4 flex-wrap">
    <%= link_to "All", polls_path, class: "badge text-decoration-none", style: "background-color: #{params[:category].nil? && params[:country].nil? ? '#534AB7' : '#1a1a2e'}; color: white; border: 1px solid #534AB7;" %>
    <%= link_to "Economy", polls_path(category: "economy"), class: "badge text-decoration-none", style: "background-color: #{params[:category] == 'economy' ? '#03C988' : '#1a1a2e'}; color: #{params[:category] == 'economy' ? '#000957' : 'white'}; border: 1px solid #03C988;" %>
    <%= link_to "Politics", polls_path(category: "politics"), class: "badge text-decoration-none", style: "background-color: #{params[:category] == 'politics' ? '#FF204E' : '#1a1a2e'}; color: white; border: 1px solid #FF204E;" %>
    <%= link_to "Social", polls_path(category: "social"), class: "badge text-decoration-none", style: "background-color: #{params[:category] == 'social' ? '#FFC193' : '#1a1a2e'}; color: #{params[:category] == 'social' ? '#000957' : 'white'}; border: 1px solid #FFC193;" %>
    <%= link_to "France", polls_path(country: "france"), class: "badge text-decoration-none", style: "background-color: #{params[:country] == 'france' ? '#0055A4' : '#1a1a2e'}; color: white; border: 1px solid #0055A4;" %>
    <%= link_to "Global", polls_path(country: "global"), class: "badge text-decoration-none", style: "background-color: #{params[:country] == 'global' ? '#4635B1' : '#1a1a2e'}; color: white; border: 1px solid #4635B1;" %>
  </div>

  <% @polls.each do |poll| %>
    <div class="card mb-3">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-2">
          <p class="fw-bold mb-0"><%= poll.title_question %></p>
          <%= button_to poll_path(poll), method: :delete, class: "btn btn-sm p-0 border-0 bg-transparent text-danger ms-2" do %>
            <i class="fas fa-trash"></i>
          <% end %>
        </div>

        <% category_colors = { "economy" => "#03C988", "politics" => "#FF204E", "social" => "#FFC193" } %>
        <% country_colors = { "france" => "#0055A4", "global" => "#4635B1" } %>
        <div class="d-flex gap-2 mb-3">
          <span class="badge" style="background-color: <%= category_colors[poll.category] %> !important; color: white;">
            <%= poll.category %>
          </span>
          <span class="badge" style="background-color: <%= country_colors[poll.country] %> !important; color: white;">
            <%= poll.country %>
          </span>
        </div>

        <div class="row g-2 mb-3">
          <div class="col-6">
            <%= button_to "Yes", poll_votes_path(poll),
                params: { answer: "yes" },
                class: "btn btn-success w-100 vote-btn",
                data: { poll_id: poll.id } %>
          </div>
          <div class="col-6">
            <%= button_to "No", poll_votes_path(poll),
                params: { answer: "no" },
                class: "btn btn-danger w-100 vote-btn",
                data: { poll_id: poll.id } %>
          </div>
        </div>

        <% yes_count = poll.votes.where(answer: "yes").count %>
        <% no_count = poll.votes.where(answer: "no").count %>
        <% total = yes_count + no_count %>
        <% yes_pct = total > 0 ? (yes_count.to_f / total * 100).round : 0 %>
        <% no_pct = 100 - yes_pct %>
        <div class="d-flex justify-content-between mb-1 small">
          <span class="text-success">Yes <%= yes_pct %>%</span>
          <span class="text-danger">No <%= no_pct %>%</span>
        </div>
        <div class="progress" style="height: 8px;">
          <div class="progress-bar bg-success" style="width: <%= yes_pct %>%;"></div>
          <div class="progress-bar bg-danger" style="width: <%= no_pct %>%;"></div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<script>
  window.votedPolls = window.votedPolls || {};
  document.querySelectorAll(".vote-btn").forEach(btn => {
    btn.addEventListener("click", function(e) {
      const pollId = this.closest("form").action;
      if (window.votedPolls[pollId]) {
        e.preventDefault();
        alert("You already voted on this poll!");
      } else {
        window.votedPolls[pollId] = true;
      }
    });
  });
</script>
