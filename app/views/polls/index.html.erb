<div class="container my-4">
  <h1 class="mb-4">Polls</h1>

  <% @polls.each do |poll| %>
    <div class="card mb-3">
      <div class="card-body">
        <p class="card-text fw-bold"><%= poll.title_question %></p>
        <div class="d-flex gap-2 mb-2">
          <span class="badge bg-secondary"><%= poll.category %></span>
          <span class="badge bg-secondary"><%= poll.country %></span>
        </div>
        <div class="d-flex gap-2">
          <%= button_to "Yes", poll_votes_path(poll), params: { answer: "yes" }, class: "btn btn-success btn-sm" %>
          <%= button_to "No", poll_votes_path(poll), params: { answer: "no" }, class: "btn btn-danger btn-sm" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
