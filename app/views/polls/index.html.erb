<div class="container my-4">

  <% filter_colors = { "economy" => "#03C988", "politics" => "#FF204E", "social" => "#FFC193", "france" => "#0055A4", "global" => "#4635B1" } %>
  <div class="dropdown mb-2">
    <button class="badge dropdown-toggle text-decoration-none border-0"
            data-bs-toggle="dropdown"
            style="background-color: <%= params[:country].present? && params[:country] != 'global' ? '#0055A4' : '#1a1a2e' %>; color: white; border: 1px solid #0055A4 !important;">
      <%= params[:country].present? && params[:country] != 'global' ? ISO3166::Country[params[:country]]&.iso_short_name : "Country" %>
    </button>
    <ul class="dropdown-menu" style="max-height: 300px; overflow-y: auto; background-color: #1a1a2e;">
      <%= content_tag :li, link_to("All countries", polls_path(category: params[:category]), class: "dropdown-item text-white") %>
      <% ISO3166::Country.all.sort_by(&:iso_short_name).each do |c| %>
        <%= content_tag :li, link_to(c.iso_short_name, polls_path(country: c.alpha2, category: params[:category]), class: "dropdown-item text-white") %>
      <% end %>
    </ul>
  </div>

  <div class="d-flex gap-2 mb-4 flex-wrap">
    <%= link_to "All", polls_path, class: "badge text-decoration-none", style: "background-color: #{params[:category].nil? && params[:country].nil? ? '#534AB7' : '#1a1a2e'}; color: white; border: 1px solid #534AB7;" %>
    <%= link_to "Economy", polls_path(category: "economy"), class: "badge text-decoration-none", style: "background-color: #{params[:category] == 'economy' ? '#03C988' : '#1a1a2e'}; color: #{params[:category] == 'economy' ? '#000957' : 'white'}; border: 1px solid #03C988;" %>
    <%= link_to "Politics", polls_path(category: "politics"), class: "badge text-decoration-none", style: "background-color: #{params[:category] == 'politics' ? '#FF204E' : '#1a1a2e'}; color: white; border: 1px solid #FF204E;" %>
    <%= link_to "Social", polls_path(category: "social"), class: "badge text-decoration-none", style: "background-color: #{params[:category] == 'social' ? '#FFC193' : '#1a1a2e'}; color: #{params[:category] == 'social' ? '#000957' : 'white'}; border: 1px solid #FFC193;" %>
    <%= link_to "Global", polls_path(country: "global"), class: "badge text-decoration-none", style: "background-color: #{params[:country] == 'global' ? '#4635B1' : '#1a1a2e'}; color: white; border: 1px solid 
     #4635B1;" %>
  </div>

  <% @polls.each do |poll| %>
    <div class="card mb-3">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-2">
          <p class="fw-bold mb-0"><%= poll.title_question %></p>
          <% if poll.user == current_user %>
            <%= button_to poll_path(poll), method: :delete, class: "btn btn-sm p-0 border-0 bg-transparent ms-2", style: "color: #FF204E;" do %>
              <i class="fas fa-trash"></i>
            <% end %>
          <% end %>
        </div>

        <% category_colors = { "economy" => "#03C988", "politics" => "#FF204E", "social" => "#FFC193" } %>
        <% country_colors = { "france" => "#0055A4", "global" => "#4635B1" } %>
        <div class="d-flex gap-2 mb-3">
          <span class="badge" style="background-color: <%= category_colors[poll.category] %> !important; color: white;">
            <%= poll.category %>
          </span>
          <span class="badge" style="background-color: <%= country_colors[poll.country] %> !important; color: white;">
            <%= poll.country == "global" || poll.country.nil? ? "Global" : (ISO3166::Country[poll.country]&.iso_short_name || poll.country) %>

          </span>
        </div>

        <% user_vote = @user_votes&.[](poll.id) %>
        <% option_colors = ["#03C988", "#FF204E", "#534AB7", "#FFC193"] %>
        <div class="row g-2 mb-3">
          <% poll.poll_options.each do |option| %>
            <div class="col">
              <% voted = user_vote&.poll_option_id == option.id %>
              <%= button_to option.text, poll_votes_path(poll),
                  params: { poll_option_id: option.id },
                  class: "btn w-100#{voted ? ' disabled' : ''}",
                  style: "background-color: #{voted ? '#3a3a5c' : '#1a1a2e'}; color: #{voted ? '#888' : 'white'}; border: 1px solid #{voted ? '#3a3a5c' : '#534AB7'}; cursor: #{voted ? 'default' : 'pointer'};",
                  disabled: voted %>
            </div>
          <% end %>
        </div>

        <% votes_arr = poll.votes.to_a %>
        <% total = votes_arr.size %>
        <% poll.poll_options.each_with_index do |option, i| %>
          <% count = votes_arr.count { |v| v.poll_option_id == option.id } %>
          <% pct = total > 0 ? (count.to_f / total * 100).round : 0 %>
          <div class="d-flex justify-content-between mb-1 small">
            <span style="color: <%= option_colors[i] %>"><%= option.text %></span>
            <span style="color: <%= option_colors[i] %>"><%= pct %>%</span>
          </div>
          <div class="progress mb-2" style="height: 6px;">
            <div class="progress-bar" style="width: <%= pct %>%; background-color: <%= option_colors[i] %>;"></div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
