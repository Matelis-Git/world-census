<div class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h6 class="fw-bold mb-0" style="color: #03C988;">My Votes</h6>

    <%= link_to my_polls_polls_path, style: "font-size: 0.78rem; color: #03C988; text-decoration: none;" do %>
      See my polls <i class="fas fa-chevron-right ms-1" style="font-size: 10px;"></i>
    <% end %>
  </div>

  <% if @votes.empty? %>
    <div class="card">
      <div class="card-body text-center py-5" style="color: rgba(255,255,255,0.35); font-size: 0.85rem;">
        You haven't voted on any polls yet.
        <%= link_to "Browse polls", polls_path, style: "color: #03C988;" %>
      </div>
    </div>
  <% else %>
    <% @votes.each do |vote| %>
      <%= render "polls/voted_poll", vote: vote %>
    <% end %>
  <% end %>
</div>
