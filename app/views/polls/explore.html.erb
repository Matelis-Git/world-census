<%# app/views/polls/explore.html.erb %>

<style>
  .explore-page { max-width: 430px; margin: 0 auto; padding: 0 0 100px; }

  .search-bar { padding: 12px 16px 0; }
  .search-wrapper { position: relative; }
  .search-bar input { width: 100%; background: rgba(255,255,255,0.05) !important; border: 0.5px solid rgba(255,255,255,0.09) !important; border-radius: 16px; color: rgba(255,255,255,0.92) !important; font-size: 13px; padding: 10px 14px 10px 38px; outline: none !important; box-sizing: border-box; caret-color: #03C988; -webkit-appearance: none; box-shadow: none !important; }
  .search-bar input:focus { background: rgba(255,255,255,0.07) !important; border-color: rgba(3,201,136,0.4) !important; outline: none !important; box-shadow: none !important; }
  .search-bar input::placeholder { color: rgba(207,226,255,0.3) !important; }
  .search-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: rgba(207,226,255,0.3) !important; font-size: 13px; pointer-events: none; z-index: 1; }

  .filters { display: flex; gap: 6px; padding: 14px 16px 0; overflow-x: auto; scrollbar-width: none; }
  .filters::-webkit-scrollbar { display: none; }
  .filter-pill { font-size: 11px; font-weight: 600; padding: 6px 16px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.15); color: rgba(207,226,255,0.5); white-space: nowrap; text-decoration: none; flex-shrink: 0; }
  .filter-pill.active { background: #5b5fcf; color: #fff; border-color: #5b5fcf; }

  .tabs { display: flex; gap: 24px; padding: 14px 16px 0; border-bottom: 1px solid rgba(255,255,255,0.08); margin-bottom: 16px; }
  .tab { font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.45); padding-bottom: 10px; text-decoration: none; border-bottom: 2px solid transparent; margin-bottom: -1px; }
  .tab:hover { color: rgba(255,255,255,0.75); border-bottom-color: rgba(123,126,248,0.4); }
  .tab.active { color: #fff; border-bottom-color: #7b7ef8; }

  .explore-list { padding: 0 16px; }
  .explore-card { background: rgba(255,255,255,0.05); border-radius: 16px; border: 0.5px solid rgba(255,255,255,0.09); padding: 14px; display: flex; align-items: center; gap: 12px; margin-bottom: 10px; text-decoration: none; transition: background 0.15s, transform 0.2s ease; }
  .explore-card:hover { background: rgba(255,255,255,0.08); transform: scale(1.02); }

  .explore-avatar { width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; background: rgba(255,255,255,0.06); border: 1.5px solid rgba(255,255,255,0.08); }

  .explore-body { flex: 1; min-width: 0; }
  .explore-question { color: rgba(255,255,255,0.92); font-size: 13px; font-weight: 700; line-height: 1.3; margin: 0 0 5px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .explore-meta { font-size: 10px; color: rgba(207,226,255,0.28); margin: 0 0 5px; }
  .explore-voted { font-size: 11px; color: rgba(207,226,255,0.55); }
  .explore-voted-option { font-weight: 700; color: rgba(130,210,160,0.9); }
</style>

<div class="explore-page">

  <%# Search bar %>
  <div class="search-bar">
    <div class="search-wrapper">
      <i class="fa-solid fa-magnifying-glass search-icon"></i>
      <%= form_tag explore_polls_path, method: :get, style: "margin: 0;" do %>
      <%# On conserve le tab et la catégorie actifs pendant la recherche %>
      <%= hidden_field_tag :tab, params[:tab] %>
      <%= text_field_tag :query, params[:query], placeholder: "Search polls..." %>
      <% end %>
    </div>
  </div>

 <%# Filtres — copie pixel-perfect de index.html.erb %>
<div class="d-flex gap-2 mb-2 flex-wrap" style="padding: 14px 16px 0;">
  <%= link_to "All", explore_polls_path,
      class: "badge text-decoration-none",
      style: "background-color: #{params[:category].nil? && params[:country].nil? ? '#534AB7' : '#1a1a2e'}; color: white; border: 1px solid #534AB7;" %>
  <%= link_to "Economy", explore_polls_path(category: "economy"),
      class: "badge text-decoration-none",
      style: "background-color: #{params[:category] == 'economy' ? '#03C988' : '#1a1a2e'}; color: #{params[:category] == 'economy' ? '#000957' : 'white'}; border: 1px solid #03C988;" %>
  <%= link_to "Politics", explore_polls_path(category: "politics"),
      class: "badge text-decoration-none",
      style: "background-color: #{params[:category] == 'politics' ? '#FF204E' : '#1a1a2e'}; color: white; border: 1px solid #FF204E;" %>
  <%= link_to "Law", explore_polls_path(category: "law"),
      class: "badge text-decoration-none",
      style: "background-color: #{params[:category] == 'law' ? '#FFA500' : '#1a1a2e'}; color: white; border: 1px solid #FFA500;" %>
  <%= link_to "Social", explore_polls_path(category: "social"),
      class: "badge text-decoration-none",
      style: "background-color: #{params[:category] == 'social' ? '#FFC193' : '#1a1a2e'}; color: #{params[:category] == 'social' ? '#000957' : 'white'}; border: 1px solid #FFC193;" %>
  <%= link_to "Global", explore_polls_path(category: "global"),
      class: "badge text-decoration-none",
      style: "background-color: #{params[:category] == 'global' ? '#4635B1' : '#1a1a2e'}; color: white; border: 1px solid #4635B1;" %>
</div>

  <%# Tabs — fonctionnels via params[:tab] %>
<div class="tabs">
  <a href="<%= explore_polls_path(tab: 'newest', category: params[:category]) %>"
     class="tab <%= @tab == 'newest' || @tab.nil? ? 'active' : '' %>">
     Newest
  </a>
  <a href="<%= explore_polls_path(tab: 'most_voted', category: params[:category]) %>"
     class="tab <%= @tab == 'most_voted' ? 'active' : '' %>">
     Most Voted
  </a>
  <a href="<%= explore_polls_path(tab: 'trending', category: params[:category]) %>"
     class="tab <%= @tab == 'trending' ? 'active' : '' %>">
     Trending
  </a>
</div>

  <%# Liste des cards %>
  <div class="explore-list">
    <% @polls.each do |poll| %>
      <%
        cat = poll.category.to_s.downcase
        emoji = { "technology" => "🤖", "economy" => "💰", "environment" => "🌍",
                  "politics" => "🏛️", "social" => "👥", "global" => "🌐", "law" => "⚖️"
                }.fetch(cat, "💬")

        # ✅ Même palette badges que _poll.html.erb
        cat_colors = { "economy" => "#03C988", "politics" => "#FF204E", "social" => "#FFC193",
                       "law" => "#FFA500", "environment" => "#4ecb8d", "technology" => "#7b8fff" }
        cty_colors = { "FR" => "#0055A4", "global" => "#4635B1", "DE" => "#FFCC00",
                       "BR" => "#009C3B", "AR" => "#74ACDF", "CO" => "#FCD116" }
        cat_color = cat_colors[cat] || "#534AB7"
        cty_color = cty_colors[poll.country] || "#4635B1"

        user_vote     = @user_votes&.[](poll.id)
        total         = poll.votes.size
        votes_affiche = total >= 1000 ? "#{(total / 1000.0).round(1)}K" : total.to_s

        # ✅ Même palette options que _poll.html.erb
        option_colors = ["#03C988", "#FF7A2F", "#06B6D4", "#FFEB00"]
        donut_values  = poll.poll_options.map { |o| poll.votes.count { |v| v.poll_option_id == o.id } }
        donut_labels  = poll.poll_options.map(&:text)
        donut_colors  = poll.poll_options.each_with_index.map { |_, i| option_colors[i % option_colors.size] }
      %>

      <a href="<%= poll_path(poll) %>" class="explore-card">

        <%# Avatar emoji %>
        <div class="explore-avatar"><%= emoji %></div>

        <%# Corps texte %>
        <div class="explore-body">

          <%# Badges — copie exacte de _poll.html.erb %>
          <div class="d-flex gap-2 mb-2">
            <span class="badge" style="background-color: <%= cat_color %> !important; color: white;">
              <%= poll.category %>
            </span>
            <span class="badge" style="background-color: <%= cty_color %> !important; color: white;">
              <%= poll.country == "global" ? "Global" : (ISO3166::Country[poll.country]&.iso_short_name || poll.country) %>
            </span>
          </div>

          <p class="explore-question"><%= poll.title_question %></p>
          <p class="explore-meta"><%= votes_affiche %> votes</p>

          <% if poll.user %>
            <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 4px;">
              <img src="<%= poll.user.avatar_url(20) %>"
                   style="width: 20px; height: 20px; border-radius: 50%;"
                   alt="<%= poll.user.email.split('@').first %>">
              <span style="font-size: 10px; color: rgba(207,226,255,0.45);">
                Asked by <%= poll.user.email.split("@").first.capitalize %>
              </span>
            </div>
          <% end %>

          <% if user_vote %>
            <% option_votee = poll.poll_options.find { |o| o.id == user_vote.poll_option_id }&.text %>
            <span class="explore-voted">✅ You voted: <span class="explore-voted-option"><%= option_votee %></span></span>
          <% end %>

        </div>

        <%# Donut — wrapper fixe 80x80 %>
        <div style="flex-shrink: 0; width: 80px; height: 80px; align-self: center;">
          <canvas data-controller="donut"
        data-donut-values="<%= donut_values.to_json %>"
        data-donut-labels="<%= donut_labels.to_json %>"
        data-donut-colors="<%= donut_colors.to_json %>"
        id="donut-<%= poll.id %>"
        width="80"
        height="80"
        style="display: block;">
          </canvas>
        </div>
      </a>
    <% end %>
  </div>

</div>
