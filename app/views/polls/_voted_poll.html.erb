<% option_colors = ["#03C988", "#FF204E", "#534AB7", "#FFC193"] %>
<% poll = vote.poll %>
<% votes_arr = poll.votes.to_a %>
<% total = votes_arr.size %>

<div class="card mb-3">
  <div class="card-body py-3">
    <p class="fw-semibold mb-3" style="font-size: 0.9rem;"><%= poll.title_question %></p>

    <% poll.poll_options.each_with_index do |option, i| %>
      <% count = votes_arr.count { |v| v.poll_option_id == option.id } %>
      <% pct = total > 0 ? (count.to_f / total * 100).round : 0 %>
      <% selected = vote.poll_option_id == option.id %>

      <div class="mb-2">
        <div class="d-flex justify-content-between align-items-center mb-1">
          <span style="font-size: 0.8rem; color: <%= selected ? option_colors[i] : 'rgba(255,255,255,0.5)' %>; font-weight: <%= selected ? '600' : '400' %>;">
            <%= option.text %>
            <% if selected %><i class="fas fa-check ms-1" style="font-size: 9px;"></i><% end %>
          </span>
          <span style="font-size: 0.75rem; color: <%= option_colors[i] %>; font-weight: 600;"><%= pct %>%</span>
        </div>
        <div class="progress" style="height: 6px; background-color: #1a1a2e;">
          <div class="progress-bar" style="width: <%= pct %>%; background-color: <%= option_colors[i] %>; opacity: <%= selected ? '1' : '0.35' %>;"></div>
        </div>
      </div>
    <% end %>

    <div class="mt-2" style="font-size: 0.75rem; color: rgba(255,255,255,0.35);"><%= total %> vote<%= total == 1 ? '' : 's' %></div>
  </div>
</div>
