  <% category_colors = { "economy" => "#03C988", "politics" => "#FF204E", "social" => "#FFC193", "law" => "#FFA500" } %>

<% country_colors = { "france" => "#0055A4", "global" => "#4635B1" } %>
<% option_colors = ["#03C988", "#FF7A2F", "#06B6D4", "#FFEB00"] %>

<div class="container my-4" style="max-width: 600px;">

  <%# BACK BUTTON %>
  <%= link_to polls_path, class: "text-decoration-none d-inline-flex align-items-center gap-1 mb-4", style: "color: rgba(255,255,255,0.5); font-size: 0.85rem;" do %>
    <i class="fas fa-arrow-left"></i> Back
  <% end %>

  <%# POLL HEADER %>
  <h4 class="fw-bold mb-3"><%= @poll.title_question %></h4>

  <div class="d-flex gap-2 mb-2 flex-wrap">
    <% if category_colors[@poll.category] %>
      <span class="badge" style="background-color: <%= category_colors[@poll.category] %> !important; color: #0d0d1a;">
        <%= @poll.category %>
      </span>
    <% end %>
    <% if country_colors[@poll.country] %>
      <span class="badge" style="background-color: <%= country_colors[@poll.country] %> !important; color: white;">
        <%= @poll.country %>
      </span>
    <% end %>
  </div>

  <p class="mb-4" style="font-size: 0.8rem; color: rgba(255,255,255,0.4);">
    Asked by <%= @poll.user&.username || @poll.user&.email&.split("@")&.first || "anonymous" %>
    &middot; <%= time_ago_in_words(@poll.created_at) %> ago
    &middot; <%= @poll.votes.size %> vote<%= @poll.votes.size == 1 ? "" : "s" %>
  </p>

  <%# OVERALL RESULTS CARD %>
  <% votes_arr = @poll.votes.to_a %>
  <% total = votes_arr.size %>
  <% has_voted = @user_vote.present? %>

  <div class="card mb-3" data-controller="bar-chart">
    <div class="card-body">
      <p class="fw-semibold mb-3" style="font-size: 0.85rem; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.05em;">Overall Results</p>

      <% if has_voted %>
        <% @poll.poll_options.each_with_index do |option, i| %>
          <% count = votes_arr.count { |v| v.poll_option_id == option.id } %>
          <% pct = total > 0 ? (count.to_f / total * 100).round : 0 %>
          <% selected = @user_vote.poll_option_id == option.id %>
          <% color = option_colors[i % option_colors.length] %>
          <div class="mb-2 position-relative" style="height: 28px; border-radius: 50px; background-color: rgba(255,255,255,0.07); overflow: hidden;">
            <div class="bar-fill" data-bar-chart-target="bar" data-pct="<%= pct %>" style="position: absolute; left: 0; top: 0; height: 100%; width: 0%; background-color: <%= color %>; overflow: hidden; transition: width 0.7s cubic-bezier(0.4,0,0.2,1);">
              <div style="position:absolute; top:-6px; right:-18px; width:36px; height:40px; border-radius:40%; background:<%= color %>; opacity:0.5; animation:waveAnim 1.2s infinite linear;"></div>
              <div style="position:absolute; top:-4px; right:-22px; width:36px; height:36px; border-radius:40%; background:<%= color %>; opacity:0.35; animation:waveAnim 1.8s infinite linear reverse;"></div>
            </div>
            <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: space-between; padding: 0 14px;">
              <span style="font-size: 0.85rem; color: white; font-weight: <%= selected ? '600' : '400' %>; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 78%;">
                <%= option.text %><% if selected %> <i class="fas fa-check" style="font-size: 9px;"></i><% end %>
              </span>
              <span style="font-size: 0.8rem; color: white; font-weight: 600; flex-shrink: 0; margin-left: 8px;"><%= pct %>%</span>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="row g-2">
          <% @poll.poll_options.each_with_index do |option, i| %>
            <div class="col-12">
              <%= button_to option.text, poll_votes_path(@poll),
                  params: { poll_option_id: option.id },
                  class: "btn w-100",
                  style: "background-color: #1a1a2e; color: white; border: 1px solid #06B6D4; cursor: pointer;" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# MAP CARD %>
  <div class="card mb-3">
    <div class="card-body">
      <p class="fw-semibold mb-3" style="font-size: 0.85rem; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.05em;">How countries voted</p>
      <div data-controller="choropleth-map"
           data-choropleth-map-api-key-value="<%= ENV['MAPBOX_API_KEY'] %>"
           data-choropleth-map-votes-value="<%= @votes_by_country.to_json %>"
           style="height: 300px; border-radius: 8px;"></div>
    </div>
  </div>

  <%# TABS %>
  <div class="card">
    <div class="card-body">
      <ul class="nav nav-tabs mb-3" style="border-bottom-color: rgba(255,255,255,0.1);">
        <li class="nav-item">
          <a class="nav-link active" data-bs-toggle="tab" href="#tab-discussion" style="font-size: 0.85rem;">Discussion</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" data-bs-toggle="tab" href="#tab-ai" style="font-size: 0.85rem;">AI Summary</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" data-bs-toggle="tab" href="#tab-related" style="font-size: 0.85rem;">Related Polls</a>
        </li>
      </ul>

      <div class="tab-content">
        <div class="tab-pane fade show active" id="tab-discussion"
             data-controller="discussion"
             style="padding-bottom:70px;">

          <%# Live stream subscription %>
          <%= turbo_stream_from "poll_#{@poll.id}_comments" %>

          <%# Comment count %>
          <p class="mb-3" style="font-size:0.78rem; color:rgba(255,255,255,0.35);">
            <%= @comments.sum { |c| 1 + c.replies.size } %> comment<%= (@comments.sum { |c| 1 + c.replies.size }) == 1 ? "" : "s" %>
          </p>

          <%# Scrollable comments list %>
          <div id="comments-poll-<%= @poll.id %>"
               style="max-height:440px; overflow-y:auto; display:flex; flex-direction:column; gap:16px;
                      padding-right:4px; margin-bottom:16px;">
            <% if @comments.empty? %>
              <p style="font-size:0.83rem; color:rgba(255,255,255,0.25); text-align:center; padding:24px 0;">
                No comments yet — be the first to share your thoughts.
              </p>
            <% else %>
              <% @comments.each do |comment| %>
                <%= render "poll_comments/comment", comment: comment %>
              <% end %>
            <% end %>
          </div>

          <%# Divider %>
          <hr style="border-color:rgba(255,255,255,0.08); margin:0 0 14px;">

          <%# Comment form or sign-in prompt %>
          <% if user_signed_in? %>
            <%= render "poll_comments/form", poll: @poll %>
          <% else %>
            <p style="font-size:0.82rem; color:rgba(255,255,255,0.35); text-align:center; padding:8px 0;">
              <%= link_to "Sign in", new_user_session_path, style: "color:#06B6D4;" %> to join the discussion.
            </p>
          <% end %>
        </div>
        <div class="tab-pane fade" id="tab-ai">
          <p style="font-size: 0.85rem; color: rgba(255,255,255,0.35);">AI summary coming soon.</p>
        </div>
        <div class="tab-pane fade" id="tab-related">
          <p style="font-size: 0.85rem; color: rgba(255,255,255,0.35);">Related polls coming soon.</p>
        </div>
      </div>
    </div>
  </div>

</div>

