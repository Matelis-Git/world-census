<div class="card mb-3" id="poll-<%= poll.id %>">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start mb-2">
      <%= link_to poll.title_question, poll_path(poll), class: "fw-bold mb-0 text-decoration-none text-white" %>
      <% if poll.user == current_user %>
        <%= button_to poll_path(poll), method: :delete, class: "btn btn-sm p-0 border-0 bg-transparent ms-2", style: "color: #FF204E;" do %>
          <i class="fas fa-trash"></i>
        <% end %>
      <% end %>
    </div>

    <% category_colors = { "economy" => "#03C988", "politics" => "#FF7A2F", "social" => "#FFEB00" } %>
    <% country_colors = { "france" => "#0055A4", "global" => "#4635B1" } %>
    <div class="d-flex gap-2 mb-3">
      <span class="badge" style="background-color: <%= category_colors[poll.category] %> !important; color: white;">
        <%= poll.category %>
      </span>
      <span class="badge" style="background-color: <%= country_colors[poll.country] %> !important; color: white;">
        <%= poll.country %>
      </span>
    </div>

    <% option_colors = ["#03C988", "#FF7A2F", "#06B6D4", "#FFEB00"] %>
    <% has_voted = user_vote.present? %>
    <div class="row g-2 mb-3">
      <% poll.poll_options.each_with_index do |option, i| %>
        <div class="col-12">
          <% voted = user_vote&.poll_option_id == option.id %>
          <% if voted
               btn_style = "background-color: #1a1a2e; color: white; border: 2px solid #{option_colors[i]}; cursor: default;"
             elsif has_voted
               btn_style = "background-color: #111120; color: #444; border: 1px solid #222; cursor: default;"
             else
               btn_style = "background-color: #1a1a2e; color: white; border: 1px solid #06B6D4; cursor: pointer;"
             end %>
          <%= button_to option.text, poll_votes_path(poll),
              params: { poll_option_id: option.id },
              class: "btn w-100",
              style: btn_style,
              disabled: voted %>
        </div>
      <% end %>
    </div>

    <% votes_arr = poll.votes.to_a %>
    <% total = votes_arr.size %>
    <% poll.poll_options.each_with_index do |option, i| %>
      <% count = votes_arr.count { |v| v.poll_option_id == option.id } %>
      <% pct = total > 0 ? (count.to_f / total * 100).round : 0 %>
      <% color = option_colors[i % option_colors.length] %>
      <% selected = user_vote&.poll_option_id == option.id %>
      <div class="mb-2 position-relative" style="height: 28px; border-radius: 50px; background-color: rgba(255,255,255,0.07); overflow: hidden;">
        <div style="position: absolute; left: 0; top: 0; height: 100%; width: <%= pct %>%; background-color: <%= color %>;"></div>
        <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: space-between; padding: 0 14px;">
          <span style="font-size: 0.8rem; color: white; font-weight: <%= selected ? '600' : '400' %>; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 78%;">
            <%= option.text %><% if selected %> <i class="fas fa-check" style="font-size: 9px;"></i><% end %>
          </span>
          <span style="font-size: 0.75rem; color: white; font-weight: 600; flex-shrink: 0; margin-left: 8px;"><%= pct %>%</span>
        </div>
      </div>
    <% end %>
  </div>
</div>
