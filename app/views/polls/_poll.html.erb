<div class="card mb-3" id="poll-<%= poll.id %>">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start mb-2">
      <p class="fw-bold mb-0"><%= poll.title_question %></p>
      <% if poll.user == current_user %>
        <%= button_to poll_path(poll), method: :delete, class: "btn btn-sm p-0 border-0 bg-transparent ms-2", style: "color: #FF204E;" do %>
          <i class="fas fa-trash"></i>
        <% end %>
      <% end %>
    </div>

    <% category_colors = { "economy" => "#03C988", "politics" => "#FF204E", "social" => "#FFC193" } %>
    <% country_colors = { "france" => "#0055A4", "global" => "#4635B1" } %>
    <div class="d-flex gap-2 mb-3">
      <span class="badge" style="background-color: <%= category_colors[poll.category] %> !important; color: white;">
        <%= poll.category %>
      </span>
      <span class="badge" style="background-color: <%= country_colors[poll.country] %> !important; color: white;">
        <%= poll.country %>
      </span>
    </div>

    <% option_colors = ["#03C988", "#FF204E", "#534AB7", "#FFC193"] %>
    <div class="row g-2 mb-3">
      <% poll.poll_options.each do |option| %>
        <div class="col-6 col-sm">
          <% voted = user_vote&.poll_option_id == option.id %>
          <%= button_to option.text, poll_votes_path(poll),
              params: { poll_option_id: option.id },
              class: "btn w-100",
              style: "background-color: #{voted ? '#3a3a5c' : '#1a1a2e'}; color: #{voted ? '#888' : 'white'}; border: 1px solid #{voted ? '#3a3a5c' : '#534AB7'}; cursor: #{voted ? 'default' : 'pointer'};",
              disabled: voted %>
        </div>
      <% end %>
    </div>

    <% votes_arr = poll.votes.to_a %>
    <% total = votes_arr.size %>
    <% poll.poll_options.each_with_index do |option, i| %>
      <% count = votes_arr.count { |v| v.poll_option_id == option.id } %>
      <% pct = total > 0 ? (count.to_f / total * 100).round : 0 %>
      <div class="d-flex justify-content-between mb-1 small">
        <span style="color: <%= option_colors[i] %>"><%= option.text %></span>
        <span style="color: <%= option_colors[i] %>"><%= pct %>%</span>
      </div>
      <div class="progress mb-2" style="height: 6px;">
        <div class="progress-bar" style="width: <%= pct %>%; background-color: <%= option_colors[i] %>;"></div>
      </div>
    <% end %>
  </div>
</div>
