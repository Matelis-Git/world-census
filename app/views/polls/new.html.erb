<div class="auth-wrapper">
  <div class="auth-card-stack">
    <div class="auth-card">
      <h2 class="mb-4">Add a Poll</h2>
      <%= simple_form_for @poll, html: { data: { controller: "poll-ai-helper poll-options" } } do |f| %>
        <%= f.input :title_question, label: "Your question", placeholder: "Should France...?",
            input_html: { data: { "poll-ai-helper-target": "question" } } %>
          <div class="mb-3">
    <label class="form-label fw-semibold">Category</label>
    <div class="dropdown">
      <button class="btn w-100 text-start dropdown-toggle"
              type="button"
              data-bs-toggle="dropdown"
              style="background-color: #1a1a2e; color: white; border: 1px solid #534AB7;">
        Economy
      </button>
      <ul class="dropdown-menu w-100" style="background-color: #1a1a2e;">
        <% ["economy", "politics", "social", "law"].each do |cat| %>
          <li>
            <a class="dropdown-item text-white" href="#"
               onclick="selectCategory('<%= cat %>', this)"><%= cat.capitalize %></a>
          </li>
        <% end %>
      </ul>
      <input type="hidden" name="poll[category]" id="categoryHiddenInput" value="economy"
             data-poll-ai-helper-target="category">
    </div>
  </div>


        <div class="mb-3">
          <label class="form-label fw-semibold">Country</label>
          <div class="dropdown">
            <button class="btn w-100 text-start dropdown-toggle"
                    type="button"
                    id="countryDropdown"
                    data-bs-toggle="dropdown"
                    data-poll-ai-helper-target="countryButton"
                    style="background-color: #1a1a2e; color: white; border: 1px solid #0055A4;">
              Global
            </button>
            <ul class="dropdown-menu w-100" style="max-height: 300px; overflow-y: auto; background-color: #1a1a2e;">
              <li>
                <a class="dropdown-item text-white" href="#"
                   data-value="global"
                   data-action="click->poll-ai-helper#selectCountry">Global</a>
              </li>
              <% ISO3166::Country.all.sort_by(&:iso_short_name).each do |c| %>
                <li>
                  <a class="dropdown-item text-white" href="#"
                     data-value="<%= c.alpha2 %>"
                     data-action="click->poll-ai-helper#selectCountry"><%= c.iso_short_name %></a>
                </li>
              <% end %>
            </ul>
            <input type="hidden" name="poll[country]" id="countryHiddenInput" value="global"
                   data-poll-ai-helper-target="country">
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">Answer options</label>
          <div data-poll-options-target="optionsList" data-poll-ai-helper-target="optionsList">
            <%= f.simple_fields_for :poll_options do |o| %>
              <div class="d-flex gap-2 mb-2 poll-option-item">
                <%= o.input :text, label: false, placeholder: "Option",
                    wrapper_html: { class: "flex-grow-1 mb-0" },
                    input_html: { class: "form-control", maxlength: 50 } %>
                <button type="button" class="btn btn-outline-danger btn-sm align-self-center"
                        data-action="click->poll-options#remove">✕</button>
              </div>
            <% end %>
          </div>
          <button type="button" class="btn btn-outline-secondary btn-sm mt-1"
                  data-action="click->poll-options#add"
                  data-poll-options-target="addButton"
                  id="add-option-btn">
            + Add option
          </button>
        </div>

        <div class="row g-2 mt-2">
          <div class="col-6">
            <%= f.submit "Publish poll", class: "btn btn-form w-100", style: "background-color: #03C988; color: #000957;" %>
          </div>
          <div class="col-6">
            <button class="btn btn-ai w-100" data-action="click->poll-ai-helper#generateWithAI">
              <i class="fas fa-robot me-1"></i> AI help
            </button>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

    <script>
    function handleCategoryChange(value) {
      const optionsList = document.querySelector('[data-poll-ai-helper-target="optionsList"]')
      const addBtn = document.getElementById("add-option-btn")
      if (!optionsList) return
  
      if (value === "law") {
        optionsList.innerHTML = `
          <div class="d-flex gap-2 mb-2 poll-option-item">                                                                               
            <input type="text" name="poll[poll_options_attributes][0][text]" class="form-control" value="For" readonly style="pointer-events: none; cursor:
  default;" />
          </div>
          <div class="d-flex gap-2 mb-2 poll-option-item">
            <input type="text" name="poll[poll_options_attributes][1][text]" class="form-control" value="Against" readonly style="pointer-events: none; 
  cursor: default;" />
          </div>
          <div class="d-flex gap-2 mb-2 poll-option-item">
            <input type="text" name="poll[poll_options_attributes][2][text]" class="form-control" value="Abstain" readonly style="pointer-events: none; 
  cursor: default;" />
          </div>
        `
        if (addBtn) addBtn.style.display = "none"
      } else {
        optionsList.innerHTML = `
          <div class="d-flex gap-2 mb-2 poll-option-item">
            <input type="text" name="poll[poll_options_attributes][0][text]" class="form-control" placeholder="Option" maxlength="50" /> 
            <button type="button" class="btn btn-outline-danger btn-sm align-self-center" data-action="click->poll-options#remove">✕</button>
          </div>
          <div class="d-flex gap-2 mb-2 poll-option-item">
            <input type="text" name="poll[poll_options_attributes][1][text]" class="form-control" placeholder="Option" maxlength="50" />
            <button type="button" class="btn btn-outline-danger btn-sm align-self-center" data-action="click->poll-options#remove">✕</button>
          </div>
        `   
        if (addBtn) addBtn.style.display = ""
      }
    }

    function selectCategory(value, el) {                                         
      document.getElementById('categoryHiddenInput').value = value                                                                       
      el.closest('.dropdown').querySelector('button').textContent = el.textContent
      handleCategoryChange(value)
    }
  </script>
