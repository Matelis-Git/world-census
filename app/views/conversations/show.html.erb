<%# app/views/conversations/show.html.erb %>
<%= turbo_stream_from @conversation %>

<div class="census-page"
     data-controller="census-ai"
     data-turbo-cache="false">

  <%# Topbar %>
  <div class="census-topbar">
    <div>
      <div class="census-title">Census AI</div>
      <div class="census-subtitle">Your global intelligence interface</div>
    </div>
    <% if user_signed_in? %>
      <img src="<%= current_user.avatar_url(32) %>"
           style="width:32px;height:32px;border-radius:50%;border:1px solid rgba(139,92,246,0.3);"
           alt="<%= current_user.username %>" />
    <% end %>
  </div>

  <%# Globe D3 + particules %>
  <div class="globe-wrap" data-census-ai-target="globe">
    <svg id="cai-svg"></svg>
    <canvas data-census-ai-target="canvas"
            width="280" height="280"
            style="position:absolute;top:0;left:0;pointer-events:none;">
    </canvas>
  </div>

  <%# Statut de l'IA %>
  <div class="globe-status">
    <div class="globe-sdot" data-census-ai-target="sdot"></div>
    <span class="globe-slabel" data-census-ai-target="slabel">Ready — ask me anything</span>
  </div>

  <%# Messages du chat %>
  <div class="census-chat" id="chat-messages">
    <% @messages.where(role: ["user", "assistant"]).each do |message| %>
     <%= render "conversations/message", message: message %>
    <% end %>
  </div>

  <%# Input + envoi %>
  <%= form_with model: [@conversation, @new_message],
        url: conversation_chat_messages_path(@conversation),
        data: {
          action: "submit->census-ai#send",
          census_ai_target: "form"
        } do |f| %>
    <div class="census-input-row">
      <%= f.text_area :content,
          placeholder: "Ask Census AI...",
          rows: 1,
          autocomplete: "off",
          class: "census-input",
          data: {
            "census-ai-target": "input",
            action: "input->census-ai#typing keydown->census-ai#_redraw"
          } %>
      <%= f.submit "↑", class: "census-send" %>
    </div>
  <% end %>

</div>

<script>
document.addEventListener("turbo:load", function() {
  const chat = document.getElementById('chat-messages')
  if (chat) chat.scrollTop = chat.scrollHeight
})
</script>
