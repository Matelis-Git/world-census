<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "World Census" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="World Census">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flag-icons@7.2.3/css/flag-icons.min.css">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= favicon_link_tag %>
  </head>
  <body>
    <% if !current_page?(root_path) || user_signed_in? %>
    <%= render "shared/topbar" %>
    <% end %>
    <% if notice %>
      <div class="alert alert-info alert-dismissible fade show m-2" role="alert">
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="alert alert-warning alert-dismissible fade show m-2" role="alert">
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        <%= alert %>
      </div>
    <% end %>

    <div style="min-height: calc(100vh - 120px);">
      <%= yield %>
    </div>


    <nav class="fixed-bottom d-flex" style="background-color: #211951; z-index: 999;">
      <%= link_to polls_path, class: "bottom-nav-link d-flex flex-column align-items-center justify-content-end gap-1 pt-3 pb-1 text-decoration-none text-white #{current_page?(polls_path) ? 'active' : ''}", style: "width: 20%;" do %>
        <i class="fa-solid fa-square-poll-vertical" style="font-size: 1.3125rem;"></i>
        <span style="font-size: 9px;">Home</span>
        <div class="nav-pill"></div>
      <% end %>
      <%= link_to "#", class: "bottom-nav-link d-flex flex-column align-items-center justify-content-end gap-1 pt-3 pb-1 text-decoration-none text-white", style: "width: 20%;" do %>
        <i class="fa-solid fa-magnifying-glass" style="font-size: 1.3125rem;"></i>
        <span style="font-size: 9px;">Explore</span>
        <div class="nav-pill"></div>
      <% end %>
      <%= link_to new_poll_path, class: "bottom-nav-link d-flex flex-column align-items-center justify-content-end gap-1 pt-3 pb-1 text-decoration-none text-white position-relative #{current_page?(new_poll_path) ? 'active' : ''}", style: "width: 20%;" do %>
        <div style="position: absolute; top: -14px; left: 50%; transform: translateX(-50%);">
          <div class="rounded-circle d-flex align-items-center justify-content-center"
            style="width: 48px; height: 48px; background-color: #03C988;">
            <i class="fa-solid fa-plus text-white" style="font-size: 1.3125rem;"></i>
          </div>
        </div>
        <span style="font-size: 9px;">Add</span>
        <div class="nav-pill"></div>
      <% end %>
      <%= link_to "#", class: "bottom-nav-link d-flex flex-column align-items-center justify-content-end gap-1 pt-3 pb-1 text-decoration-none text-white", style: "width: 20%;" do %>
        <i class="fa-regular fa-bell" style="font-size: 1.3125rem;"></i>
        <span style="font-size: 9px;">Notifications</span>
        <div class="nav-pill"></div>
      <% end %>
      <%= link_to new_conversation_path, class: "bottom-nav-link d-flex flex-column align-items-center justify-content-end gap-1 pt-3 pb-1 text-decoration-none text-white #{current_page?(new_conversation_path) ? 'active' : ''}", style: "width: 20%;" do %>
        <i class="fa-solid fa-robot" style="font-size: 1.3125rem;"></i>
        <span style="font-size: 9px;">AI</span>
        <div class="nav-pill"></div>
      <% end %>
    </nav>
    <%= yield :scripts %>
    <script>
      function animateBars() {
        document.querySelectorAll('.bar-fill:not([data-animated])').forEach(function(bar) {
          bar.dataset.animated = 'true';
          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              bar.style.width = bar.dataset.pct + '%';
            });
          });
        });
      }
      document.addEventListener('DOMContentLoaded', animateBars);
      document.addEventListener('turbo:render', animateBars);
      document.addEventListener('turbo:load', animateBars);
    </script>
  </body>
</html>
