<script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/topojson/3.0.2/topojson.min.js"></script>

<div id="globe-bg" style="position:fixed;inset:0;z-index:0;background:#00224D;pointer-events:none;">
  <svg id="gs-bg" style="width:100%;height:100%;"></svg>
  <svg id="pins-bg" style="position:absolute;top:0;left:0;pointer-events:none;overflow:visible;"></svg>
</div>

<script>
const GLOBE_POLLS = <%= @globe_polls.map(&:to_globe_json).to_json.html_safe %>;
const IS_ROOT     = <%= current_page?(root_path).to_s %>;

(function(){
  const BLUE = {
    100:'#cfe2ff',200:'#9ec5fe',300:'#6ea8fe',
    400:'#3d8bfd',500:'#0d6efd',600:'#0a58ca',
    700:'#084298',800:'#052c65',900:'#031633',
  };
  const CAT = {
    economy:{col:'#3d8bfd'},politics:{col:'#9ec5fe'},
    social:{col:'#6ea8fe'},global:{col:'#cfe2ff'},
  };

  function padId(id){ return String(id).padStart(3,'0'); }

  function init(){
    const W = window.innerWidth, H = window.innerHeight;
    const R = Math.min(W,H) * 0.43;
    const opacity = IS_ROOT ? 1 : 0.4;

    const proj = d3.geoOrthographic()
      .scale(R).translate([W/2,H/2])
      .clipAngle(90).rotate([0,-20]);

    const gpath = d3.geoPath().projection(proj);
    const grat  = d3.geoGraticule()();

    const svg  = d3.select('#gs-bg').attr('width',W).attr('height',H).style('opacity', opacity);
    const defs = svg.append('defs');

    defs.append('clipPath').attr('id','gbg-clip')
      .append('circle').attr('cx',W/2).attr('cy',H/2).attr('r',R);

    const og = defs.append('radialGradient').attr('id','gbg-ocean').attr('cx','38%').attr('cy','33%');
    og.append('stop').attr('offset','0%').attr('stop-color','#055160');
    og.append('stop').attr('offset','100%').attr('stop-color','#032830');
    svg.append('circle').attr('cx',W/2).attr('cy',H/2).attr('r',R).attr('fill','url(#gbg-ocean)');

    svg.append('path').datum(grat)
      .attr('stroke','rgba(13,202,240,0.15)').attr('stroke-width','0.5')
      .attr('fill','none').attr('clip-path','url(#gbg-clip)');

    const cg = svg.append('g').attr('clip-path','url(#gbg-clip)');

    const sg = defs.append('radialGradient').attr('id','gbg-spec').attr('cx','32%').attr('cy','26%');
    sg.append('stop').attr('offset','0%').attr('stop-color','rgba(158,234,249,0.18)');
    sg.append('stop').attr('offset','55%').attr('stop-color','rgba(158,234,249,0)');
    svg.append('circle').attr('cx',W/2).attr('cy',H/2).attr('r',R)
      .attr('fill','url(#gbg-spec)').attr('pointer-events','none');

    const ag = defs.append('radialGradient').attr('id','gbg-atmo').attr('cx','50%').attr('cy','50%');
    ag.append('stop').attr('offset','85%').attr('stop-color','rgba(13,202,240,0)');
    ag.append('stop').attr('offset','100%').attr('stop-color','rgba(13,202,240,0.25)');
    svg.append('circle').attr('cx',W/2).attr('cy',H/2).attr('r',R+10)
      .attr('fill','url(#gbg-atmo)').attr('pointer-events','none');

    svg.append('circle').attr('cx',W/2).attr('cy',H/2).attr('r',R)
      .attr('fill','none').attr('stroke','rgba(10,162,192,0.65)').attr('stroke-width','1.5')
      .attr('pointer-events','none');

    let borders = null;

    function redraw(){
      cg.selectAll('path').attr('d',d=>gpath(d));
      if(borders) d3.select('#gbg-border').datum(borders).attr('d',gpath);
    }

    d3.json('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json')
      .then(world => {
        const countries = topojson.feature(world, world.objects.countries);
        borders = topojson.mesh(world, world.objects.countries, (a,b)=>a!==b);

        svg.append('path').attr('id','gbg-border')
          .attr('fill','none').attr('stroke','rgba(8,121,144,0.85)').attr('stroke-width','0.7')
          .attr('clip-path','url(#gbg-clip)');

        cg.selectAll('path').data(countries.features).join('path')
          .attr('d',d=>gpath(d))
          .attr('fill','rgba(158,234,249,0.22)');

        d3.select('#gbg-border').datum(borders).attr('d',gpath);
        drawPins();
      });

    function isVisible(lat,lon){
      const r=proj.rotate();
      const dLon=((lon-(-r[0])+180)%360+360)%360-180;
      const dLat=lat-(-r[1]);
      return Math.abs(dLon)<88&&Math.abs(dLat)<88;
    }

    function drawPins(){
      const psvg=d3.select('#pins-bg').attr('width',W).attr('height',H).style('opacity',opacity);
      psvg.selectAll('*').remove();
      if(!IS_ROOT) return;
      GLOBE_POLLS.forEach(p=>{
        if(!isVisible(p.lat,p.lon)) return;
        const base=proj([p.lon,p.lat]);
        if(!base) return;
        const col=CAT[p.cat]?.col??BLUE[400];
        const tip=[base[0],base[1]-18];
        psvg.append('line')
          .attr('x1',base[0]).attr('y1',base[1])
          .attr('x2',tip[0]).attr('y2',tip[1])
          .attr('stroke',col+'cc').attr('stroke-width',1.3);
        psvg.append('circle')
          .attr('cx',tip[0]).attr('cy',tip[1])
          .attr('r',3.5).attr('fill',col);
      });
    }

    let lastT=0;
    (function animate(t){
      if(lastT){
        const r=proj.rotate();
        proj.rotate([r[0]+(t-lastT)*0.018,r[1],r[2]]);
        redraw();
      }
      lastT=t;
      requestAnimationFrame(animate);
    })(0);

    window.addEventListener('resize',()=>{
      const nW=window.innerWidth,nH=window.innerHeight;
      svg.attr('width',nW).attr('height',nH);
      d3.select('#pins-bg').attr('width',nW).attr('height',nH);
      proj.translate([nW/2,nH/2]);
      redraw();
    });
  }

  setTimeout(init,100);
})();
</script>
