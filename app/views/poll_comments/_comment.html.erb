<div id="comment-<%= comment.id %>"
     data-author-id="<%= comment.user_id %>"
     class="discussion-comment <%= 'discussion-reply' if comment.parent_id %>"
     data-action="pointerdown->discussion#holdStart pointerup->discussion#holdEnd pointercancel->discussion#holdEnd pointermove->discussion#holdMove"
     style="user-select:none; -webkit-user-select:none;">

  <div class="d-flex gap-2 align-items-start">

    <%# Avatar %>
    <% username = comment.user.username.presence || comment.user.email.split("@").first %>
    <div style="width:30px; height:30px; border-radius:50%; background:<%= avatar_color(username) %>; flex-shrink:0;
                display:flex; align-items:center; justify-content:center;
                font-size:0.75rem; font-weight:700; color:#0d0d1a;">
      <%= username.first.upcase %>
    </div>

    <div class="flex-grow-1" style="min-width:0;">
      <%# Header %>
      <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
        <span style="font-size:0.82rem; font-weight:600; color:white;">@<%= username %></span>
        <span style="font-size:0.72rem; color:rgba(255,255,255,0.35);"><%= time_ago_in_words(comment.created_at) %> ago</span>
      </div>

      <%# Body with @mention highlighting %>
      <div style="font-size:0.85rem; color:rgba(255,255,255,0.85); word-break:break-word; line-height:1.45;">
        <%= highlight_mentions(comment.body) %>
      </div>

      <%# Reply button (top-level only) %>
      <% unless comment.parent_id %>
        <button class="btn btn-link p-0 mt-1"
                style="font-size:0.75rem; color:rgba(255,255,255,0.35); text-decoration:none;"
                data-action="click->discussion#startReply"
                data-username="<%= username %>"
                data-comment-id="<%= comment.id %>">
          <i class="fas fa-reply" style="font-size:0.65rem;"></i> Reply
        </button>
      <% end %>
    </div>

  </div>

  <%# Hidden delete form — submitted programmatically on long-press confirm %>
  <%= button_to poll_poll_comment_path(comment.poll_id, comment),
        method: :delete,
        form: { class: "comment-delete-form", style: "display:none;" } do %>
  <% end %>

  <%# Replies container (top-level only) %>
  <% unless comment.parent_id %>
    <div id="replies-<%= comment.id %>"
         class="mt-2 ms-4 ps-3"
         style="border-left:2px solid rgba(255,255,255,0.07); display:flex; flex-direction:column; gap:12px;">
      <% comment.replies.order(:created_at).each do |reply| %>
        <%= render partial: "poll_comments/comment", locals: { comment: reply } %>
      <% end %>
    </div>
  <% end %>

</div>
