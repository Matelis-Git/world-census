<div class="auth-wrapper">
  <div class="auth-card-stack">
    <div class="auth-card">
      <h2 class="mb-4 text-center">Sign up</h2>

      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= f.error_notification %>

        <div class="form-inputs">
            <%= f.input :username, required: true, autofocus: true,
      placeholder: "Choose a username" %>

          <%= f.input :email,
                      required: true,
                      autofocus: true,
                      input_html: { autocomplete: "email" } %>
          <%= f.input :password,
                      required: true,
                      hint: (@minimum_password_length ? "<span style='color: rgba(255, 255, 255, 0.5)'>#{@minimum_password_length} characters minimum</span>".html_safe : nil),
                      input_html: { autocomplete: "new-password" } %>
          <%= f.input :password_confirmation,
                      required: true,
                      input_html: { autocomplete: "new-password" } %>
            <div class="mb-3">
    <label class="form-label">Country</label>
    <div class="dropdown">
      <button class="btn w-100 text-start dropdown-toggle" type="button"
              id="countrySignupBtn"
              data-bs-toggle="dropdown"
              style="background-color: #1a1a2e; color: white; border: 1px solid #0055A4;">
        Stay anonymous
      </button>
      <ul class="dropdown-menu w-100" style="max-height: 300px; overflow-y: auto; background-color: #1a1a2e;">
        <li>
          <a class="dropdown-item text-white" href="#"
             data-signup-country="" onclick="selectSignupCountry('', 'Stay anonymous', this); return false;">Stay anonymous</a>
        </li>
        <% ISO3166::Country.all.sort_by(&:iso_short_name).each do |c| %>
          <li>
            <a class="dropdown-item text-white" href="#"
                 onclick="selectSignupCountry('<%= c.alpha2 %>', '<%= j(c.iso_short_name) %>', this); return false;">
              <%= c.iso_short_name %>
            </a>
          </li>
        <% end %>
      </ul>
      <input type="hidden" name="user[country]" id="countrySignupInput" value="">
    </div>
  </div>

        </div>

        <div class="form-actions">
          <%= f.button :submit, "Sign up", class: "btn btn-neon w-100 mt-2" %>
        </div>
      <% end %>

      <div class="text-center mt-3">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
  <script>
    function selectSignupCountry(value, label, el) {
      document.getElementById('countrySignupInput').value = value
      document.getElementById('countrySignupBtn').textContent = label
    }
  </script>
